# ===========================================
# Anything2Ontology - Environment Variables
# ===========================================
# 使用火山引擎 (豆包) OpenAI 兼容 API

# --- I/O Paths ---
INPUT_DIR=G:/Program Files/AI coding/知识萃取/新能源/输入
OUTPUT_DIR=G:/Program Files/AI coding/知识萃取/新能源/输出
LOG_DIR=./logs

# --- API Keys ---
# 火山引擎 API Key (必需 - 用于 LLM 分词、提取、嵌入)
ARK_API_KEY=ark-d0608b79-bf7a-4464-9381-60fc43d7476e-83fbd
SILICONFLOW_API_KEY=sk-eca1fddd05fc49cf861283ec7e6ddba3

# MinerU API key (可选 - 复杂/扫描 PDF 解析)
MINERU_API_KEY=d8efff0f-108d-492a-981e-655123a0dc99

# FireCrawl API key (可选 - 网页爬取)
FIRECRAWL_API_KEY=

# --- Processing Configuration ---
RETRY_COUNT=1
RETRY_DELAY_SECONDS=2

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=both

# --- Language ---
LANGUAGE=zh

# --- LLM Configuration (火山引擎 Ark - OpenAI 兼容) ---
SILICONFLOW_BASE_URL=https://api.deepseek.com
# 豆包主模型 endpoint (使用官方文档中的模型ID)
CHUNKING_MODEL=deepseek-v4-flash
COMPLEX_MODEL=deepseek-v4-flash
EXTRACTION_MODEL=deepseek-v4-pro
CHATBOT_MODEL=deepseek-v4-pro
DEDUP_SCAN_MODEL=deepseek-v4-pro
# 嵌入模型暂用 SiliconFlow (火山暂无 bge-m3 endpoint)
EMBEDDING_MODEL=deepseek-v4-pro
CHATBOT_MAX_TOKENS=16000

# 飞书多维表格配置
FEISHU_BITABLE_APP_TOKEN=C1qybEyn9am06FspDb2czASQnif
FEISHU_BITABLE_TABLE_ID=tbli9vrIAMgLfbvP

# 飞书云文档模板
FEISHU_DOC_TEMPLATE_TOKEN=ReHwdBdiAoBpKzx3y4YclU1Xnbc
