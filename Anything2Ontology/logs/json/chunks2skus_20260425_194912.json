\u672f\u63d0\u4f9b\u5546', '\u670d\u52a1\u5185\u5bb9': '\u4e3a\u5176\u4ed6\u865a\u62df\u7535\u5382\u5efa\u8bbe\u63d0\u4f9b\u8f6f\u786c\u4ef6\u6280\u672f\u3001\u7269\u8054\u7f51\u5e73\u53f0\u7b49\u6280\u672f\u670d\u52a1'}]}, {'name': '\u6df1\u5733\u5730\u533a\u7a7a\u8c03\u865a\u62df\u7535\u5382\u9700\u6c42\u4fa7\u54cd\u5e94\u76c8\u5229\u89c4\u5219', 'description': '\u6df1\u5733\u5730\u533a\u865a\u62df\u7535\u5382\u53c2\u4e0e\u9700\u6c42\u4fa7\u54cd\u5e94\u7684\u5e02\u573a\u5206\u7c7b\u3001\u5b9a\u4ef7\u89c4\u5219\u53ca\u6536\u76ca\u5206\u914d\u65b9\u5f0f', 'content_type': 'markdown', 'content': '\u6df1\u5733\u865a\u62df\u7535\u5382\u9700\u6c42\u4fa7\u54cd\u5e94\u5206\u4e3a\u65e5\u524d\u548c\u65e5\u5185\u4e24\u7c7b\u5e02\u573a\uff1a1.\u65e5\u524d\u5e02\u573a\uff1a\u9700\u4f01\u4e1a\u62a5\u91cf\u62a5\u4ef7\u53c2\u4e0e\uff0c\u670d\u52a1\u8d39\u4e3a1.5-3.5\u5143/\u5ea6\uff1b2.\u65e5\u5185\u5e02\u573a\uff1a\u4ec5\u9700\u62a5\u91cf\uff0c\u670d\u52a1\u8d39\u56fa\u5b9a\u4e3a5\u5143/\u5ea6\uff0c\u5e02\u573a\u5360\u6bd4\u8f83\u5c0f\uff1b\u54cd\u5e94\u65f6\u957f\u4e00\u822c\u4ee51\u5c0f\u65f6\u4e3a\u4e3b\uff0c15\u5206\u949f\u4e3a\u4e00\u4e2a\u8282\u70b9\uff0c\u53ef\u8c03\u8282\u91cf\u6309\u529f\u7387\u53d8\u5316\u8ba1\u7b97\uff0c\u670d\u52a1\u8d39\u6309\u7167\u5b9e\u9645\u54cd\u5e94\u7684\u7535\u91cf\u6838\u7b97\uff0c\u6536\u76ca\u7531\u865a\u62df\u7535\u5382\u5e73\u53f0\u4e0e\u7a7a\u8c03\u7528\u6237\u5171\u4eab\u3002'}, {'name': '\u6052\u5b9e\u76db\u666f2025\u5e746\u6708\u9700\u6c42\u4fa7\u54cd\u5e94\u6848\u4f8b\u6570\u636e', 'description': '2025\u5e746\u6708\u6052\u5b9e\u76db\u666f\u53c2\u4e0e\u6df1\u5733\u7d27\u6025\u9700\u6c42\u54cd\u5e94\u7684\u5b9e\u9645\u6548\u679c\u53ca\u6536\u76ca\u6570\u636e', 'content_type': 'json', 'content': {'\u54cd\u5e94\u65f6\u95f4': '2025\u5e746\u6708\u67d0\u65e5\u4e2d\u5348', '\u89e6\u53d1\u539f\u56e0': '\u7535\u7f51\u7a81\u53d1\u8d1f\u8377\u538b\u529b\u589e\u5927\uff0c\u6df1\u5733\u865a\u62df\u7535\u5382\u7ba1\u7406\u4e2d\u5fc3\u53d1\u51fa\u7d27\u6025\u54cd\u5e94\u6307\u4ee4', '\u54cd\u5e94\u901f\u5ea6': '1\u5206\u949f\u5185\u8c03\u52a823\u4e2a\u7a7a\u8c03\u7528\u6237\u53c2\u4e0e\u54cd\u5e94', '\u8c03\u63a7\u63aa\u65bd': '\u7a7a\u8c03\u6e29\u5ea6\u4ece24\u2103\u5347\u81f326\u2103\uff0c\u98ce\u673a\u8f6c\u901f\u5e73\u7a33\u4e0b\u8c03\uff0c\u54cd\u5e94\u524dAI\u63d0\u524d\u5728\u7535\u4ef7\u4f4e\u8c37\u65f6\u6bb5\u4e8e\u84c4\u51b7\u8bbe\u5907\u50a8\u51b7', '\u54cd\u5e94\u65f6\u957f': '1\u5c0f\u65f6', '\u524a\u5cf0\u6548\u679c': '\u524a\u5cf015.79\u5146\u74e6\uff0c\u76f8\u5f53\u4e8e1.3\u4e07\u53f0\u5bb6\u7528\u7a7a\u8c03\u540c\u65f6\u5173\u95ed\uff0c\u8282\u7535\u8fd11.6\u4e07\u5ea6', '\u7528\u6237\u4f53\u611f\u5f71\u54cd': '\u73af\u5883\u6e29\u5ea6\u6700\u5927\u6e29\u5dee\u4ec51.2\u2103\uff0c\u7528\u6237\u51e0\u4e4e\u65e0\u611f\u77e5', '\u6536\u76ca\u60c5\u51b5': '\u6309\u65e5\u5185\u5e02\u573a5\u5143/\u5ea6\u8ba1\u7b97\uff0c\u670d\u52a1\u8d39\u8fd18\u4e07\u5143'}}, {'name': '\u7a7a\u8c03\u7528\u6237\u53c2\u4e0e\u865a\u62df\u7535\u5382\u7684\u6536\u76ca\u8bf4\u660e', 'description': '\u7a7a\u8c03\u7528\u6237\u53c2\u4e0e\u865a\u62df\u7535\u5382\u53ef\u83b7\u5f97\u7684\u6536\u76ca\u7c7b\u578b\u53ca\u5178\u578b\u573a\u666f\u6536\u76ca\u6570\u636e', 'content_type': 'markdown', 'content': '\u7a7a\u8c03\u7528\u6237\u53c2\u4e0e\u865a\u62df\u7535\u5382\u53ef\u83b7\u5f97\u53cc\u91cd\u6536\u76ca\uff1a1.\u964d\u4f4e\u7528\u7535\u91cf\u4ea7\u751f\u7684\u8282\u7535\u6536\u76ca\uff1b2.\u9700\u6c42\u4fa7\u54cd\u5e94\u670d\u52a1\u8d39\u5206\u6210\u6536\u76ca\uff1b\u5178\u578b\u6848\u4f8b\uff1a\u9762\u79ef7-8\u4e07\u5e73\u65b9\u7c73\u7684\u5199\u5b57\u697c\uff0c\u7a7a\u8c03\u53ef\u8c03\u91cf\u7ea6700-800\u5343\u74e6\uff0c\u6bcf\u5e74\u53ef\u83b7\u5f97\u8fd110\u4e07\u5143\u54cd\u5e94\u670d\u52a1\u8d39+\u6570\u4e07\u5143\u8282\u7535\u6536\u76ca\uff0c\u5408\u8ba1\u5e74\u6536\u76ca\u8d8510\u4e07\u5143\uff1b\u7528\u6237\u53c2\u4e0e\u865a\u62df\u7535\u5382\u65e0\u9700\u4ed8\u51fa\u4efb\u4f55\u6210\u672c\uff0c\u65e0\u6295\u5165\u