# 环境变量配置模板
# 复制此文件为 .env 并填写真实值

# ====================
# LLM 配置
# ====================
OPENAI_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ====================
# 飞书配置（lark-oapi SDK 必需）
# ====================
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token
FEISHU_BITABLE_TABLE_ID=your_main_table_id
FEISHU_BITABLE_CONSENSUS_TABLE_ID=your_consensus_table_id
FEISHU_DOC_TEMPLATE_TOKEN=your_doc_template_token

# ====================
# 服务配置
# ====================
PORT=8501
LOG_LEVEL=info

# ====================
# 知识库配置
# ====================
KNOWLEDGE_BASE_PATH=../新能源/输出
KEYWORDS_DICT_PATH=config/keywords.json