2026-04-25T14:51:02.097082Z [info     ] [MONITOR] Facts extracted      [chunks2skus.utils.llm_client] count=10 facts_preview="[{'name': '良信零碳工厂调研基本信息', 'description': '本次良信电器零碳工厂调研的基础属性信息', 'content_type': 'markdown', 'content': '报告名称：良信电器调研报告：怎样建设零碳工厂？\\n报告发布日期：2025-12-18\\n调研对象：上海良信股份有限公司\\n调研日期：2025年11月14日\\n调研地点：浙江嘉兴海盐\\n调研内容：零碳工厂建设路径、经验及零碳园区建设相关问题'}, {'name': '低压电器定义及应用场景', 'description': '低压电器的标准定义及在电力系统中的应用范围', 'content_type': 'markdown', 'content': '低压电器是指用于交流电压1000伏及以下电路内，能根据外部信号和要求，手动或自动地接通、分断、转换、控制、保护和调节电路的电器，核心作用为电力系统的安全“开关”/“保险”，广泛分布于电力系统源网荷储所有重要线路节点，也应用于工厂、楼宇、普通家庭住宅等各类用电场景。'}, {'name': '良信股份基本经营概况', 'description': '上海良信股份有限公司的发展历程、主营业务及转型情况', 'content_type': 'markdown', 'content': '良信股份成立于1999年，是中国领先的低压电器制造商、深圳证券交易所上市企业，生产的低压电器覆盖信息通讯、新能源、建筑地产、电网、发电、工控、工业建筑等30多个细分行业；2024年4月成立子公司良云智慧能源（广东）有限公司，专注提供零碳园区建设服务；通过自建海盐零碳工厂，实现了从低压电器制造商到零碳园区一体化建设服务商的转型。'}, {'name': '海盐零碳工厂核心参数', 'description': '良信股份海盐零碳工厂（杭州湾超级工厂）的规模、用能、认证、投资收益等核心指标', 'content_type': 'json', 'content': {'规模属性': {'占地面积': '206亩', '建筑面积': '27万平', '规划年产值': '100亿元', '行业定位': '中国大陆地区规模最大的低压电器制造中心'}, '用能属性': {'当前新能源用能占比': '55%', '当前绿电消纳比例': '92%', '碳中和路径': '未来可通过外购碳汇实现100%碳中和运营'}, '认证信息': {'认证机构': '必维', '认证标准': '《零碳工厂评价规范 T/CECA-G:0171-2022》', '认证等级': '零碳工厂五星级'}, '投资收益': {'零碳建设总投入': '9000万元', '预计投资回收周期': '4-6年', '预计最终净收益': '1.8亿元'}}}, {'name': '海盐零碳工厂源网荷储零碳解决方案详情', 'description': '海盐零碳工厂零碳实现方案的源、网、荷、储各模块及光储直柔微电网的配置详情', 'content_type': 'json', 'content': {'源端（绿色能源供应）': {'分布式光伏': '已建成5兆瓦，年发电量600万度，自用量582万度', '分布式风电': '布局7.15兆瓦，处于手续办理阶段，投产后风光年发电量预计达2000万度'}, '网端（内部配网系统）': {'硬件配置': '6个智能主配房、400多个智能分配电箱', '管理系统': '自研软硬件一体化智能配电系统'}, '荷端（可调负荷挖掘）': {'生产可调负荷': '总容量约1.5兆瓦，占总生产负荷的12%，可调整用电节奏', '充电桩负荷': '56个交流充电桩、9个直流充电桩，总负荷1.86兆瓦，支持车网互动', '空调负荷': '总容量3.67兆瓦，采用AI控制，可实现负荷可调及节能运行', '照明负荷': '采用智能调控，可根据环境参数优化用电，实现10%-30%的用电节省'}, '储端（储能配置）': '4.75兆瓦/10兆瓦时液冷储能', '办公楼光储直柔微电网': {'类型': '并网型微电网', '配置': '光伏最大发电功率146.4千瓦，储能容量286.72千瓦时，可与工厂大网互济互动', '运行效果': '年用电约65%来自光伏，光伏发的电32%供大楼使用，68%返送工厂大网，可减少交直流转换的能源损失'}}}, {'name': 'MX微网专家软件功能说明', 'description': '良信自研MX微网专家软件的定位、调控策略及运行效果', 'content_type': 'json', 'content': {'定位': '零碳工厂的大脑，基于AI算法智能调控源网荷储设备协同运行', '支持调控策略': ['投资收益优先', '绿电消纳优先', '降碳优先', '需量管理优先：优先控制尖峰用电功率，降低基本电费', '平抑波动优先：优先保障供电稳定性，适配对电能质量敏感的生产场景'], '运行机制': '可与工厂生产执行系统（MES）联动，获取生产排产等数据做负荷预测，结合发电预测、分时电价等因素灵活调整生产策略', '运行效果': '效益优先模式下，可降低生产用电成本约10%'}}, {'name': '良信智能化配电软硬件一体化解决方案说明', 'description': '良信基于智能低压电器打造的零碳园区配电解决方案的构成及核心优势', 'content_type': 'json', 'content': {'架构层级': ['智能低压电器：负责终端数据采集，相当于能源神经系统的神经末梢', 'PTX站控单元：负责配电房分布式监控，相当于能源神经系统的神经节', 'PX配电专家：负责中心监控，相当于能源神经系统的中枢神经'], '核心优势': ['数据采集覆盖范围更广，可触达单独传感器无法覆盖的区域', '低压电器与传感器合二为一，省去仪表加装成本，节省安装空间，降低施工协调等隐形成本', '可集成温度、湿度、设备使用寿命、操作次数、触头磨损等多维度数据监测，协同实现工厂生产智能化', '依托低压电器原生控制功能，更容易实现对负荷设备的精准控制，便于能源调度和优化管理，在网、荷环节形成差异化竞争优势']}}, {'name': '零碳园区建设核心挑战及对应建议', 'description': '良信基于海盐零碳工厂建设实践总结的五大建设挑战及应对建议', 'content_type': 'json', 'content': [{'挑战类型': '安全挑战', '具体内容': '包括数据安全、设备安全、储能消防安全、光储直柔微电网直流漏电保护等', '建议': '建设前期重点考虑安全问题，规划好相关应对举措'}, {'挑战类型': '成本挑战', '具体内容': '零碳建设投入巨大，需考虑智能化是否会大幅提高用能成本', '建议': '前期明确建设目的（示范/能源转型降本）、投资主体（第三方/自建），追求经济性可选择自投提高收益'}, {'挑战类型': '方案挑战', '具体内容': '子系统模块和方案众多，相互融合易出现矛盾，导致运行策略无法落地', '建议': '建设前期做好整体规划，方便后续运营调优，避免分散模块建好后再拼装'}, {'挑战类型': '落地挑战', '具体内容': '需集成不同技术、设备、协议标准，管理大量供应商协同，系统联调过程繁琐困难', '建议': '不同供应商组建联盟，提高交互效率，降低建设成本'}, {'挑战类型': '回报率挑战', '具体内容': '市场环境、政策变化、AI算法投入等可能导致投资回报率发生变化，技术投入的增效价值需验证', '建议': '由具备集成能力的总包方统筹建设，覆盖咨询设计、施工总包、运维的一体化服务'}]}, {'name': '零碳园区合格总包方核心能力要求', 'description': '良信基于实践总结的零碳园区建设总包方需具备的核心能力', 'content_type': 'markdown', 'content': '1. 具备顶层设计与系统集成能力：可主导规划和设计，定义整个零碳系统的架构和各子模块的标准，确保所有部分无缝协同工作，避免形成技术孤岛；\\n2. 能深度理解客户业务与场景：熟悉企业经营逻辑，具备多行业电力服务积累，可设计针对性解决方案。'}, {'name': '零碳园区生态合作伙伴建设规则', 'description': '零碳园区建设的生态合作需求及协作方向', 'content_type': 'markdown', 'content': '零碳园区建设涉及多领域跨学科技术，无法由单一企业独立完成，需组建覆盖投资、总包、施工、设计、咨询认证、运行维护、售电及虚拟电厂服务、政府报建及电网接入等环节的生态合作伙伴联盟；生态伙伴可通过共享项目资源、产品方案互融互通、共同探索行业标准和技术方案的方式实现深度协同，达成1+1大于2的效果。'}]"
